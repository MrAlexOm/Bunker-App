{
  "expo": {
    "name": "Bunker",
    "slug": "bunker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0B0B0B",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "bundleIdentifier": "com.bunker.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.al0306.bunker",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro",
      "output": "single",
      "baseUrl": "./",
      "name": "Bunker",
      "shortName": "Bunker",
      "description": "Bunker - Офлайн приложение для выживания",
      "themeColor": "#0B0B0B",
      "backgroundColor": "#0B0B0B",
      "lang": "ru",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, shrink-to-fit=no"
      }
    },
    "extra": {
      "eas": {
        "projectId": "22369148-d519-485f-ab6c-c5309e2f470e"
      }
    }
  }
}
