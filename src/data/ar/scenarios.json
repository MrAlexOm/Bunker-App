{
  "war": {
    "title": "بدأت الحرب",
    "steps": [
      "احزم حقيبة الطوارئ (وثائق، ماء، طعام، دواء)",
      "اشحن جميع الأجهزة والبنوك الطاقة",
      "املأ حاويات المياه",
      "حدد أقرب ملجأ",
      "اتبع الإعلانات الرسمية"
    ]
  },
  "evacuation": {
    "title": "إخلاء طارئ",
    "steps": [
      "خذ وثائق، مال، دواء",
      "ماء وطعام لمدة 24-72 ساعة",
      "اشحن الهاتف، بنك الطاقة",
      "البس حسب الطقس",
      "تجنب التجمعات",
      "استخدم طرق آمنة"
    ]
  },
  "under_rubble": {
    "title": "أنت تحت الأنقاض",
    "steps": [
      "هدئ تنفسك، تنفس بانتظام",
      "وفر الهواء - لا تصرخ",
      "اطرق على سطح صلب كل 10-15 دقيقة",
      "إذا كان لديك مصباح - أرسل إشارة",
      "احافظ على الطاقة"
    ]
  },
  "border_closed": {
    "title": "الحدود مغلقة",
    "steps": [
      "ابحث عن مكان آمن للإقامة المؤقتة",
      "تعلم قواعد الإقامة في البلد",
      "سجل مع السلطات المحلية (إذا مطلوب)",
      "ابحث عن المساعدة الإنسانية",
      "حافظ على التواصل مع المواطنين"
    ]
  }
}
