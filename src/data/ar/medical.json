{
  "bleeding": {
    "title": "نزيف",
    "steps": [
      "طبق ضمادة ضاغطة أو رباط فوق الجرح",
      "ارفع الطرف فوق مستوى القلب",
      "لا تطلق الضغط حتى يتوقف النزيف",
      "إذا كان رباط - سجل وقت التطبيق"
    ]
  },
  "fracture": {
    "title": "كسر",
    "steps": [
      "ثبت الطرف بجبيرة (مواد مؤقتة)",
      "طبق بارد لمدة 15-20 دقيقة",
      "لا تحاول إعادة العظم",
      "احتفظ بالضحية ساكنة"
    ]
  },
  "burn": {
    "title": "حرق",
    "steps": [
      "برد تحت ماء جاري لمدة 15-20 دقيقة",
      "غطِ بضمادة معقمة",
      "لا تثقب البثور",
      "أعطِ مسكناً (إذا كان متاحاً)"
    ]
  },
  "unconscious": {
    "title": "فقدان الوعي",
    "steps": [
      "تحقق من التنفس والنبض",
      "بدون تنفس - ابدأ التنفس الاصطناعي",
      "ضع الضحية على جانبها (وضعية الإفاقة)",
      "اطلب المساعدة (إذا كانت الاتصالات متاحة)"
    ]
  },
  "poison": {
    "title": "تسمم",
    "steps": [
      "أحدث القيء (إذا كان واعياً)",
      "أعطِ فحم نشط (إذا كان متاحاً)",
      "لا تثير القيء إذا كان التسمم كيميائياً",
      "ضمن الراحة، الكثير من السوائل"
    ]
  }
}
