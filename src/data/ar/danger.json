{
  "shelling": {
    "title": "قصف",
    "steps": [
      "استلقِ على الأرض، غطِ رأسك بيديك",
      "ابحث عن ملجأ خرساني (طابق سفلي، جدار)",
      "ابتعد عن النوافذ والأبواب الزجاجية",
      "لا تركض في المناطق المفتوحة"
    ]
  },
  "collapse": {
    "title": "انهيار / تدمير المبنى",
    "steps": [
      "غطِ وجهك بيديك، احمِ رأسك",
      "تنفس من خلال القماش (إذا كان متاحاً)",
      "أعطِ إشارة: اطرق على فترات منتظمة",
      "وفر الهواء، لا تصرخ باستمرار"
    ]
  },
  "checkpoint": {
    "title": "نقطة تفتيش / عسكري",
    "steps": [
      "احتفظ بيديك مرئيتين",
      "لا تقم بحركات مفاجئة",
      "تحدث بهدوء، لا تجادل",
      "كن مستعداً بالوثائق"
    ]
  },
  "crowd": {
    "title": "ذعر / حشد",
    "steps": [
      "لا تسير عكس التيار",
      "احتفظ بيديك أمام صدرك",
      "تحرك إلى حافة الحشد",
      "ابحث عن مخرج أو ملجأ"
    ]
  },
  "no_water": {
    "title": "لا ماء / طعام",
    "steps": [
      "حدد أقرب مصادر المياه (صنابير، متاجر)",
      "اجمع مياه المطر إذا كانت متاحة",
      "قسم الإمدادات على عدة أيام",
      "نقِّ المياه بالغلي أو الأقراص"
    ]
  }
}
