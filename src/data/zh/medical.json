{
  "bleeding": {
    "title": "出血",
    "steps": [
      "在伤口上方施加压力敷料或止血带",
      "将肢体抬高至心脏水平以上",
      "不要松开压力直到出血停止",
      "如果是止血带 - 记录应用时间"
    ]
  },
  "fracture": {
    "title": "骨折",
    "steps": [
      "用夹板固定肢体（临时材料）",
      "冷敷15-20分钟",
      "不要试图复位骨头",
      "保持伤者不动"
    ]
  },
  "burn": {
    "title": "烧伤",
    "steps": [
      "在流动水下冷却15-20分钟",
      "用无菌敷料覆盖",
      "不要刺破水泡",
      "给予止痛药（如果可用）"
    ]
  },
  "unconscious": {
    "title": "失去意识",
    "steps": [
      "检查呼吸和脉搏",
      "没有呼吸 - 开始人工呼吸",
      "将伤者侧卧（恢复姿势）",
      "寻求帮助（如果有连接）"
    ]
  },
  "poison": {
    "title": "中毒",
    "steps": [
      "诱导呕吐（如果清醒）",
      "给予活性炭（如果可用）",
      "如果是化学中毒不要诱导呕吐",
      "确保休息，大量液体"
    ]
  }
}
