{
  "shelling": {
    "title": "炮击",
    "steps": [
      "趴在地上，用手护头",
      "寻找混凝土掩体（地下室，墙壁）",
      "远离窗户和玻璃门",
      "不要在开阔地带奔跑"
    ]
  },
  "collapse": {
    "title": "倒塌 / 建筑物破坏",
    "steps": [
      "用手护脸，保护头部",
      "通过布料呼吸（如果可用）",
      "发出信号：定期敲击",
      "节省空气，不要持续尖叫"
    ]
  },
  "checkpoint": {
    "title": "检查站 / 军事",
    "steps": [
      "保持双手可见",
      "不要突然动作",
      "平静说话，不要争论",
      "准备好文件"
    ]
  },
  "crowd": {
    "title": "恐慌 / 人群",
    "steps": [
      "不要逆流而行",
      "双手放在胸前",
      "移动到人群边缘",
      "寻找出口或掩体"
    ]
  },
  "no_water": {
    "title": "没有水 / 食物",
    "steps": [
      "确定最近的水源（水龙头，商店）",
      "如果可用，收集雨水",
      "将供应品分成几天",
      "通过煮沸或药片净化水"
    ]
  }
}
